{
  "manifest_version": 3,
  "name": "InnoMapCAD",
  "version": "0.3.9",
  "description": "GIS-SAPR overlay for 4dinno.ru digital twin",
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://4dinno.ru/map", "https://4dinno.ru/map/*", "https://www.4dinno.ru/map", "https://www.4dinno.ru/map/*"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": ["http://localhost:8000/*"],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://4dinno.ru/*", "https://www.4dinno.ru/*"]
    }
  ]
}
